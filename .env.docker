# Environment used by the Docker Compose stack (loaded into the app and db
# containers via env_file). Before deploying anywhere real:
#   1. Regenerate APP_KEY:  docker compose run --rm app php artisan key:generate --show
#   2. Change the DB_PASSWORD / MYSQL_* passwords below.

# Application
APP_NAME="Document Tracking Information System v2"
APP_ENV=production
APP_KEY=base64:V5tHR4RzblWFoKQcYEolSEamKWxk50kMWuI+yklX5jk=
APP_DEBUG=false
# The address users type in the browser
APP_URL=https://dtis.dohwv.net

# Trust X-Forwarded-* headers from the nginx reverse proxy container
TRUSTED_PROXIES=*
SESSION_SECURE_COOKIE=true

# External offices API (config/services.php). "host.docker.internal" reaches
# the Docker host machine; replace with the real API server address.
API_BASE_URL=http://host.docker.internal:8081/

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database - the app connects to the "db" service on the internal network.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=dtis
DB_USERNAME=dtis_user
DB_PASSWORD=secure_password_here

# MySQL container bootstrap - MYSQL_DATABASE/USER/PASSWORD must match the
# DB_* values above.
MYSQL_DATABASE=dtis
MYSQL_USER=dtis_user
MYSQL_PASSWORD=secure_password_here
MYSQL_ROOT_PASSWORD=change_this_root_password

# Cache, session & queue (served by the "redis" service)
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (configure for production)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="DTIS v2"

# AWS (only if using S3 for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Entrypoint behaviour: run "php artisan migrate --force" on container start
AUTO_MIGRATE=true
